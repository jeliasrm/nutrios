NODE_ENV=development
PORT=3001

# App runtime connects as non-superuser so RLS is enforced.
DATABASE_URL="postgresql://nutrios_app:nutrios_app_dev@localhost:5434/nutrios_dev?schema=public"

REDIS_URL="redis://:nutrios_dev@localhost:6381"

JWT_SECRET="dev-access-secret-change-in-prod"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-prod"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
