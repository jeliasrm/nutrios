    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nutrios/db": "workspace:*",
    "@nutrios/diet-engine": "workspace:*",
    "@nutrios/trpc": "workspace:*",
    "@nutrios/types": "workspace:*",
    "@nutrios/validations": "workspace:*",
    "@trpc/server": "^11",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nutrios/config": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^3.0.0",
    "supertest": "^7.2.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
